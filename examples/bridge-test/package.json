    "@mocha/native": "workspace:*",
    "@mocha/qml": "workspace:*",
    "@mocha/shared": "workspace:*",
    "@mocha/tokens": "workspace:*"
  },
  "devDependencies": {
    "@mocha/cli": "workspace:*",
    "@mocha/kit": "workspace:*",
    "typescript": "^5.5.0",
    "tsx": "^4.15.0"
  }
}
