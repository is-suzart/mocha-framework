{
  "name": "@mocha/testkit",
  "version": "0.1.0",
  "description": "Mocha TestKit — vitest custom environment for QML tests and test utilities",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./environment": {
      "types": "./dist/environment.d.ts",
      "import": "./dist/environment.js"
    },
    "./qml-runner": {
      "types": "./dist/qml-runner.d.ts",
      "import": "./dist/qml-runner.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vitest": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
