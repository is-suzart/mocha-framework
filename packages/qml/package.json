{
  "name": "@mocha/qml",
  "version": "0.1.0",
  "description": "Mocha QML - Hybrid QML + TypeScript component system",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mocha/core": "workspace:*",
    "@mocha/native": "workspace:*",
    "@mocha/shared": "workspace:*"
  }
}
