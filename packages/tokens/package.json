{
  "name": "@mocha/tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Mocha Design Tokens - Single source of truth for all platforms",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "generate:css": "tsx scripts/generate-css.ts",
    "generate:qml": "tsx scripts/generate-qml.ts",
    "generate": "tsx scripts/generate-css.ts && tsx scripts/generate-qml.ts"
  },
  "dependencies": {
    "@catppuccin/palette": "^1.8.0"
  }
}
