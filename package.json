{
  "name": "mocha-framework",
  "version": "0.1.0",
  "private": true,
  "description": "Mocha - The Qt TypeScript Framework (The bear that tames the Qt)",
  "type": "module",
  "scripts": {
    "build": "tsc -b packages/shared packages/bridge-api packages/core packages/qml packages/kit packages/cli",
    "build:core": "tsc -b packages/core",
    "build:qml": "tsc -b packages/qml",
    "build:kit": "tsc -b packages/kit",
    "build:cli": "tsc -b packages/cli",
    "dev": "tsx packages/cli/src/index.ts dev",
    "typecheck": "tsc -b --dry",
    "clean": "rimraf packages/*/dist packages/*/*.tsbuildinfo",
    "lint": "eslint packages/*/src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:qml": "qmltestrunner-qt6 -input design-system/test/tst_*.qml",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "cli": "tsx packages/cli/src/index.ts",
    "setup": "node scripts/bootstrap.mjs",
    "doctor": "tsx packages/cli/src/index.ts doctor",
    "tokens:build": "tsx packages/tokens/scripts/generate-css.ts && tsx packages/tokens/scripts/generate-qml.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
